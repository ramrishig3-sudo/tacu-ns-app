# ── CyberShield Pro Environment Variables ──────────────────
# Copy this file to .env and fill in your keys

# ── App Configuration ─────────────────────────────────────
# API base URL for frontend requests
# Dev: http://localhost:3000  |  Prod: https://<your-app>.vercel.app
VITE_API_BASE_URL=""

# ── Threat Intelligence APIs (Server-side ONLY) ──────────
VIRUSTOTAL_API_KEY=""
OTX_API_KEY=""
ABUSEIPDB_API_KEY=""
IPINFO_TOKEN=""

# ── AI Service (Server-side ONLY) ────────────────────────
GROQ_API_KEY=""

# ── Supabase ─────────────────────────────────────────────
# Public (safe for frontend)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
# Private (server-side ONLY)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ── Firebase (Server-side ONLY) ──────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
